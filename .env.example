# 鲜知 FreshKnow - 环境变量配置

# API 基础地址
# 开发环境：http://localhost:3000
# 生产环境：根据实际部署地址配置
VITE_API_BASE_URL=http://localhost:3000

# AI API 地址（用于菜谱生成）
VITE_AI_API_URL=http://localhost:3000

# 应用名称
VITE_APP_NAME=鲜知 FreshKnow

# 应用描述
VITE_APP_DESCRIPTION=让冰箱会说话，用现有食材秒出菜谱

# 主题色（绿色主题）
VITE_APP_THEME_COLOR=#22c55e

# 版本号
VITE_APP_VERSION=1.0.0

# 是否开启调试模式
VITE_DEBUG=false

# Mock 服务端口（开发环境）
VITE_MOCK_PORT=3000

# Umami 埋点配置（可选，不配置则不加载埋点）
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# 反馈表单 URL（可选，不配置则不显示反馈入口）
VITE_FEEDBACK_URL=
